{
  "cli": {
    "version": ">= 18.9.1",
    "requireCommit": true,
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "bun": "1.3.10",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "bun": "1.3.10",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "environment": "production",
      "distribution": "store",
      "autoIncrement": true,
      "bun": "1.3.10"
    }
  },
  "submit": {
    "production": {}
  }
}
